                "operator": "and",
                "conditions": [
                  {
                    "input_value": "name",
                    "compared_value": "Claroty",
                    "comparison_operator": "contains"
                  },
                  {
                    "input_value": "severity",
                    "compared_value": "[\"HIGH\",\"CRITICAL\"]",
                    "comparison_operator": "in"
                  }
                ]
              },
              "is_disabled": false,
              "run_automatically": true,
              "event_type": "alert",
              "event_subtypes": [
                "CREATE"
              ]
            },
            {
              "condition": {
                "operator": "or",
                "conditions": [
                  {
                    "input_value": "name",
                    "compared_value": "PANW Firewall",
                    "comparison_operator": "contains"
                  },
                  {
                    "input_value": "name",
                    "compared_value": "Palo Alto Networks Firewall",
                    "comparison_operator": "contains"
                  }
                ]
